# Production API URL — MUST also be set in Vercel dashboard under Settings > Environment Variables
# Replace with your deployed FastAPI backend URL (Render, Railway, Fly.io, etc.)
VITE_API_URL=https://your-backend.onrender.com

# VITE_LLM_URL is intentionally omitted in production.
# LM Studio is a local-only service. The app falls back to the backend /chat API
# or the built-in text parser automatically.
